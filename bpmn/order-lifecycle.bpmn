<?xml version="1.0" encoding="UTF-8"?>
<ns0:definitions xmlns:ns0="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:ns2="http://camunda.org/schema/zeebe/1.0" xmlns:ns3="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:ns4="http://www.omg.org/spec/DD/20100524/DC" xmlns:ns5="http://www.omg.org/spec/DD/20100524/DI" xmlns:ns1="http://camunda.org/schema/modeler/1.0" id="Definitions_OrderLifecycle" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0" ns1:executionPlatform="Camunda Cloud" ns1:executionPlatformVersion="8.9.0">
  <ns0:process id="Process_OrderLifecycle" name="Жизненный цикл заказа" isExecutable="true">
    <ns0:startEvent id="Start_OrderKafka" name="Заказ из Kafka" ns2:modelerTemplate="io.camunda.connectors.inbound.KafkaMessageStart.v1" ns2:modelerTemplateVersion="7" ns2:modelerTemplateIcon="data:image/svg+xml;base64,">
      <ns0:extensionElements>
        <ns2:properties>
          <ns2:property name="correlationKeyExpression" value="= string(value.messageObject.id)" />
          <ns2:property name="inbound.type" value="io.camunda:connector-kafka-inbound:1" />
          <ns2:property name="authenticationType" value="credentials" />
          <ns2:property name="topic.bootstrapServers" value="localhost:9092" />
          <ns2:property name="topic.topicName" value="all_orders" />
          <ns2:property name="groupId" value="camunda-lc-start" />
          <ns2:property name="autoOffsetReset" value="earliest" />
          <ns2:property name="schemaStrategy.type" value="schemaRegistry" />
          <ns2:property name="schemaStrategy.schemaType" value="avro" />
          <ns2:property name="schemaStrategy.schemaRegistryUrl" value="http://localhost:8082" />
          <ns2:property name="consumeUnmatchedEvents" value="true" />
          <ns2:property name="correlationRequired" value="notRequired" />
          <ns2:property name="deduplicationModeManualFlag" value="false" />
          <ns2:property name="deduplicationMode" value="AUTO" />
          <ns2:property name="resultVariable" value="" />
          <ns2:property name="resultExpression" value="= {&#10;  orderId       : string(value.messageObject.id),&#10;  orderStatusId : value.messageObject.statusId,&#10;  stateName     : string(value.messageObject.stateName),&#10;  shopId        : string(value.messageObject.shopId),&#10;  managerId     : string(value.messageObject.managerId),&#10;  paymentTypeId : string(value.messageObject.paymentTypeId),&#10;  orderComment  : string(value.messageObject.comment),&#10;  orderPayload  : value&#10;}" />
        </ns2:properties>
      </ns0:extensionElements>
      <ns0:outgoing>Flow_start_to_validate</ns0:outgoing>
      <ns0:messageEventDefinition id="MsgDef_Start" messageRef="Message_OrderLifecycle" />
    </ns0:startEvent>
    <ns0:exclusiveGateway id="GW_ValidateStart" name="ID заказа&#10;присутствует?" default="Flow_validate_to_invalid">
      <ns0:incoming>Flow_start_to_validate</ns0:incoming>
      <ns0:outgoing>Flow_validate_to_gw</ns0:outgoing>
      <ns0:outgoing>Flow_validate_to_invalid</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:exclusiveGateway id="GW_LoopJoin" name="Новый статус">
      <ns0:incoming>Flow_catch_to_gw</ns0:incoming>
      <ns0:incoming>Flow_validate_to_gw</ns0:incoming>
      <ns0:outgoing>Flow_join_to_route</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:exclusiveGateway id="GW_RouteByStatus" name="Маршрутизация&#10;по статусу" default="Flow_gw_to_unknown">
      <ns0:incoming>Flow_join_to_route</ns0:incoming>
      <ns0:outgoing>Flow_gw_to_oformlyaemy</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_ispolnyaemy</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_regsklad</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_kovrov</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_nsk</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_kovrov_plan</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_nsk_plan</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_delivery</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_ready</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_vnimanie</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_netkani</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_ozhidanie</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_zhduoplatu</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_centralskl</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_peremeshenie</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_rs</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_vputi</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_tranzit</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_peremes_natt</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_tochka</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_smezhnyy</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_otgruzka</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_vypolnen</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_otmenen</ns0:outgoing>
      <ns0:outgoing>Flow_gw_to_unknown</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:scriptTask id="Task_Oformlyaemy" name="Оформляемый">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_oformlyaemy</ns0:incoming>
      <ns0:outgoing>Flow_oformlyaemy_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_Ispolnyaemy" name="Исполняемый">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_ispolnyaemy</ns0:incoming>
      <ns0:outgoing>Flow_ispolnyaemy_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_Vnimanie" name="Внимание">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_vnimanie</ns0:incoming>
      <ns0:outgoing>Flow_vnimanie_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_NetKani" name="Нет ткани">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_netkani</ns0:incoming>
      <ns0:outgoing>Flow_netkani_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_Ozhidanie" name="Ожидание">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_ozhidanie</ns0:incoming>
      <ns0:outgoing>Flow_ozhidanie_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_ZhduOplatu" name="Жду оплату">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_zhduoplatu</ns0:incoming>
      <ns0:outgoing>Flow_zhduoplatu_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_KovrovProcessing" name="Обрабатывается&#10;Ковров">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_kovrov</ns0:incoming>
      <ns0:outgoing>Flow_kovrov_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_NskProcessing" name="Обрабатывается&#10;Новосибирск">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_nsk</ns0:incoming>
      <ns0:outgoing>Flow_nsk_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_KovrovPlanning" name="Ковров&#10;планирование">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_kovrov_plan</ns0:incoming>
      <ns0:outgoing>Flow_kovrov_plan_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_NskPlanning" name="Новосибирск&#10;планирование">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_nsk_plan</ns0:incoming>
      <ns0:outgoing>Flow_nsk_plan_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_Delivery" name="Поставка">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_delivery</ns0:incoming>
      <ns0:outgoing>Flow_delivery_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_CentralSkl" name="Центральный склад">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_centralskl</ns0:incoming>
      <ns0:outgoing>Flow_centralskl_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_Peremeshenie" name="Перемещение">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_peremeshenie</ns0:incoming>
      <ns0:outgoing>Flow_peremeshenie_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_RS" name="РС">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_rs</ns0:incoming>
      <ns0:outgoing>Flow_rs_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_VPuti" name="В пути">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_vputi</ns0:incoming>
      <ns0:outgoing>Flow_vputi_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_RegSklad" name="Региональный склад">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_regsklad</ns0:incoming>
      <ns0:outgoing>Flow_regsklad_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_Tranzit" name="Транзит">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_tranzit</ns0:incoming>
      <ns0:outgoing>Flow_tranzit_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_PeresTT" name="Перемещение на ТТ">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_peremes_natt</ns0:incoming>
      <ns0:outgoing>Flow_peremes_natt_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_Tochka" name="Торговая точка">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_tochka</ns0:incoming>
      <ns0:outgoing>Flow_tochka_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_ReadyToShip" name="Готов к отгрузке">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_ready</ns0:incoming>
      <ns0:outgoing>Flow_ready_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_Smezhnyy" name="Смежный склад">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_smezhnyy</ns0:incoming>
      <ns0:outgoing>Flow_smezhnyy_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_Otgruzka" name="Отгрузка завершена">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_otgruzka</ns0:incoming>
      <ns0:outgoing>Flow_otgruzka_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_Vypolnen" name="Выполнен">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_vypolnen</ns0:incoming>
      <ns0:outgoing>Flow_vypolnen_to_end</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_Otmenen" name="Отменен">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_otmenen</ns0:incoming>
      <ns0:outgoing>Flow_otmenen_to_end</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:scriptTask id="Task_Unknown" name="Неизвестный статус">
      <ns0:extensionElements>
        <ns2:script expression="= null" resultVariable="stub" />
      </ns0:extensionElements>
      <ns0:incoming>Flow_gw_to_unknown</ns0:incoming>
      <ns0:outgoing>Flow_unknown_to_join</ns0:outgoing>
    </ns0:scriptTask>
    <ns0:exclusiveGateway id="GW_StageJoin" name="Слияние этапов">
      <ns0:incoming>Flow_oformlyaemy_to_join</ns0:incoming>
      <ns0:incoming>Flow_ispolnyaemy_to_join</ns0:incoming>
      <ns0:incoming>Flow_vnimanie_to_join</ns0:incoming>
      <ns0:incoming>Flow_netkani_to_join</ns0:incoming>
      <ns0:incoming>Flow_ozhidanie_to_join</ns0:incoming>
      <ns0:incoming>Flow_zhduoplatu_to_join</ns0:incoming>
      <ns0:incoming>Flow_kovrov_to_join</ns0:incoming>
      <ns0:incoming>Flow_nsk_to_join</ns0:incoming>
      <ns0:incoming>Flow_kovrov_plan_to_join</ns0:incoming>
      <ns0:incoming>Flow_nsk_plan_to_join</ns0:incoming>
      <ns0:incoming>Flow_delivery_to_join</ns0:incoming>
      <ns0:incoming>Flow_centralskl_to_join</ns0:incoming>
      <ns0:incoming>Flow_peremeshenie_to_join</ns0:incoming>
      <ns0:incoming>Flow_rs_to_join</ns0:incoming>
      <ns0:incoming>Flow_vputi_to_join</ns0:incoming>
      <ns0:incoming>Flow_regsklad_to_join</ns0:incoming>
      <ns0:incoming>Flow_tranzit_to_join</ns0:incoming>
      <ns0:incoming>Flow_peremes_natt_to_join</ns0:incoming>
      <ns0:incoming>Flow_tochka_to_join</ns0:incoming>
      <ns0:incoming>Flow_ready_to_join</ns0:incoming>
      <ns0:incoming>Flow_smezhnyy_to_join</ns0:incoming>
      <ns0:incoming>Flow_otgruzka_to_join</ns0:incoming>
      <ns0:incoming>Flow_unknown_to_join</ns0:incoming>
      <ns0:outgoing>Flow_join_to_ebg</ns0:outgoing>
    </ns0:exclusiveGateway>
    <ns0:eventBasedGateway id="EBG_WaitUpdate" name="Ожидание&#10;обновления статуса">
      <ns0:incoming>Flow_join_to_ebg</ns0:incoming>
      <ns0:outgoing>Flow_ebg_to_catch</ns0:outgoing>
      <ns0:outgoing>Flow_ebg_to_timer</ns0:outgoing>
    </ns0:eventBasedGateway>
    <ns0:intermediateCatchEvent id="Catch_NextStatus" name="Обновление статуса&#10;из Kafka" ns2:modelerTemplate="io.camunda.connectors.inbound.KafkaIntermediate.v1" ns2:modelerTemplateVersion="7" ns2:modelerTemplateIcon="data:image/svg+xml;base64,">
      <ns0:extensionElements>
        <ns2:properties>
          <ns2:property name="inbound.type" value="io.camunda:connector-kafka-inbound:1" />
          <ns2:property name="authenticationType" value="credentials" />
          <ns2:property name="topic.bootstrapServers" value="localhost:9092" />
          <ns2:property name="topic.topicName" value="all_orders" />
          <ns2:property name="groupId" value="camunda-lc-next" />
          <ns2:property name="autoOffsetReset" value="earliest" />
          <ns2:property name="schemaStrategy.type" value="schemaRegistry" />
          <ns2:property name="schemaStrategy.schemaType" value="avro" />
          <ns2:property name="schemaStrategy.schemaRegistryUrl" value="http://localhost:8082" />
          <ns2:property name="consumeUnmatchedEvents" value="true" />
          <ns2:property name="correlationKeyExpression" value="= string(value.messageObject.id)" />
          <ns2:property name="deduplicationModeManualFlag" value="false" />
          <ns2:property name="deduplicationMode" value="AUTO" />
          <ns2:property name="resultVariable" value="" />
          <ns2:property name="resultExpression" value="= {&#10;  orderId       : string(value.messageObject.id),&#10;  orderStatusId : value.messageObject.statusId,&#10;  stateName     : string(value.messageObject.stateName),&#10;  shopId        : string(value.messageObject.shopId),&#10;  managerId     : string(value.messageObject.managerId),&#10;  paymentTypeId : string(value.messageObject.paymentTypeId),&#10;  orderComment  : string(value.messageObject.comment),&#10;  orderPayload  : value&#10;}" />
        </ns2:properties>
      </ns0:extensionElements>
      <ns0:incoming>Flow_ebg_to_catch</ns0:incoming>
      <ns0:outgoing>Flow_catch_to_gw</ns0:outgoing>
      <ns0:messageEventDefinition id="MsgDef_Catch" messageRef="Message_OrderLifecycle" />
    </ns0:intermediateCatchEvent>
    <ns0:intermediateCatchEvent id="Timer_Timeout" name="30 дней таймаут">
      <ns0:incoming>Flow_ebg_to_timer</ns0:incoming>
      <ns0:outgoing>Flow_timer_to_end</ns0:outgoing>
      <ns0:timerEventDefinition id="TimerDef_Timeout">
        <ns0:timeDuration>="P30D"</ns0:timeDuration>
      </ns0:timerEventDefinition>
    </ns0:intermediateCatchEvent>
    <ns0:endEvent id="End_Timeout" name="Таймаут ожидания">
      <ns0:incoming>Flow_timer_to_end</ns0:incoming>
    </ns0:endEvent>
    <ns0:endEvent id="End_InvalidOrder" name="Нет ID заказа">
      <ns0:incoming>Flow_validate_to_invalid</ns0:incoming>
    </ns0:endEvent>
    <ns0:endEvent id="End_Vypolnen" name="Выполнен">
      <ns0:incoming>Flow_vypolnen_to_end</ns0:incoming>
    </ns0:endEvent>
    <ns0:endEvent id="End_Otmenen" name="Отменен">
      <ns0:incoming>Flow_otmenen_to_end</ns0:incoming>
    </ns0:endEvent>
    <ns0:sequenceFlow id="Flow_start_to_validate" sourceRef="Start_OrderKafka" targetRef="GW_ValidateStart" />
    <ns0:sequenceFlow id="Flow_validate_to_gw" name="Корректный заказ" sourceRef="GW_ValidateStart" targetRef="GW_LoopJoin">
      <ns0:conditionExpression>= orderId != null</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_validate_to_invalid" sourceRef="GW_ValidateStart" targetRef="End_InvalidOrder" />
    <ns0:sequenceFlow id="Flow_join_to_route" sourceRef="GW_LoopJoin" targetRef="GW_RouteByStatus" />
    <ns0:sequenceFlow id="Flow_gw_to_oformlyaemy" name="Оформляемый" sourceRef="GW_RouteByStatus" targetRef="Task_Oformlyaemy">
      <ns0:conditionExpression>= orderStatusId = "C0003089DD24DC9A"</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_gw_to_ispolnyaemy" name="Исполняемый" sourceRef="GW_RouteByStatus" targetRef="Task_Ispolnyaemy">
      <ns0:conditionExpression>= orderStatusId = "C0008686474408E5"</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_gw_to_vnimanie" name="Внимание" sourceRef="GW_RouteByStatus" targetRef="Task_Vnimanie">
      <ns0:conditionExpression>= orderStatusId = "80010000000020AE"</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_gw_to_netkani" name="Нет ткани" sourceRef="GW_RouteByStatus" targetRef="Task_NetKani">
      <ns0:conditionExpression>= orderStatusId = "80010000000020A4"</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_gw_to_ozhidanie" name="Ожидание" sourceRef="GW_RouteByStatus" targetRef="Task_Ozhidanie">
      <ns0:conditionExpression>= orderStatusId = "8001000000001523"</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_gw_to_zhduoplatu" name="Жду оплату" sourceRef="GW_RouteByStatus" targetRef="Task_ZhduOplatu">
      <ns0:conditionExpression>= orderStatusId = "8001000000001564"</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_gw_to_kovrov" name="Обр. Ковров" sourceRef="GW_RouteByStatus" targetRef="Task_KovrovProcessing">
      <ns0:conditionExpression>= orderStatusId = "8001000000001500"</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_gw_to_nsk" name="Обр. Новосибирск" sourceRef="GW_RouteByStatus" targetRef="Task_NskProcessing">
      <ns0:conditionExpression>= orderStatusId = "8001000000001501"</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_gw_to_kovrov_plan" name="Ковров план." sourceRef="GW_RouteByStatus" targetRef="Task_KovrovPlanning">
      <ns0:conditionExpression>= orderStatusId = "800100000000011F"</ns0:conditionExpression>
    </ns0:sequenceFlow>
    <ns0:sequenceFlow id="Flow_gw_to_nsk_plan" name="Новосиб. план." sourceRef="GW_RouteByStatus" targetRef="Task_NskPlanning">
